//this is the datapath for the binary search algorithm. it takes in control signals
//				from the controller and updates staus signals accordingly

module binarySearch_datapath #(parameter W = 8)(clk, reset,  shiftA, loadA, incr_result, 
															clr_result, A, A_eq_0, a0, result);
	
	// port definitions
	input logic clk, reset;
	input logic shiftA, loadA, incr_result, clr_result;
	input logic [W-1:0] A;
	output logic [W-1:0] result;
	output logic A_eq_0, a0;
	
	logic [W-1:0] A1;
	
	// datapath logic
	always_ff @(posedge clk) begin
		if (loadA) begin
			A1 <= A;
		end
		if (clr_result) begin
			result <= 8'h00;
		end
		if (incr_result) begin
			result <= result + 1;
		end
		if (shiftA) A1 <= A1 >> 1;
	end //always_ff
	
	//assign ouputs
	assign A_eq_0 = (A1 == 0);
	assign a0 = A1[0];


endmodule 